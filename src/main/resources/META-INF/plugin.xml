<!-- Plugin Configuration File: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <!-- Unique identifier of the plugin. It should be FQN, cannot be changed between the plugin versions. -->
    <id>org.hrithikvish.lite-compose-preview</id>

    <!-- Public plugin name should be written in Title Case.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/best-practices-for-listing.html#plugin-name -->
    <name>Lite Composable Preview</name>

    <!-- A displayed Vendor name or Organization ID displayed on the Plugins Page. -->
    <vendor url="https://www.linkedin.com/in/hrithik-vishwakarma-4764ba1b6/">Hrithik Vishwakarma</vendor>

    <!-- Description of the plugin displayed on the Plugin Page and IDE Plugin Manager.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/best-practices-for-listing.html#plugin-description -->
    <description><![CDATA[
        A lightweight alternative to Android Studio's built-in Compose Preview.<br><br>
        Studio's live preview can be heavy on RAM/CPU and sometimes causes autocomplete to lag or stop
        responding entirely, even on high-end machines. This plugin renders <code>@Preview</code>
        composables out-of-process using Android Studio's <code>android</code> CLI, so you get a static
        image of your UI without loading Studio's own preview engine.<br><br>
        Click the gutter run icon next to any <code>@Preview</code> function to render it and view the
        result in a tool window.<br><br>
        <b>Trade-off:</b> no interactive previews or instant live updates &mdash; just a quick way to see
        your UI when you don't want the IDE to slow down.
    ]]></description>

    <!-- Product and plugin compatibility requirements.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html -->
    <depends>com.intellij.modules.compose</depends>

    <depends>org.jetbrains.kotlin</depends>
    <resource-bundle>messages.MyMessageBundle</resource-bundle>
    <!-- Extensions defined by the plugin.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-extension-points.html -->
    <extensions defaultExtensionNs="com.intellij">
        <toolWindow id="MyToolWindow" factoryClass="org.hrithikvish.litecomposepreview.MyToolWindowFactory"
                    icon="AllIcons.Toolwindows.ToolWindowPalette"/>
        <notificationGroup id="Lite Compose Preview" displayType="BALLOON"/>
        <codeInsight.lineMarkerProvider language="kotlin"
                    implementationClass="org.hrithikvish.litecomposepreview.ComposePreviewLineMarkerProvider"/>
    </extensions>

    <extensions defaultExtensionNs="org.jetbrains.kotlin">
        <supportsKotlinPluginMode supportsK2="true"/>
    </extensions>
</idea-plugin>